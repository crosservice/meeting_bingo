# API
NODE_ENV=production
API_PORT=3001
WEB_URL=https://your-domain.com

# Database
DATABASE_URL=postgresql://meeting_bingo:changeme@localhost:5432/meeting_bingo
DB_HOST=localhost
DB_PORT=5432
